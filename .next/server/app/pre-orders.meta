{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/pre-orders/layout,_N_T_/pre-orders/page,_N_T_/pre-orders"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/pre-orders/__PAGE__",
    "/pre-orders",
    "/_index",
    "/_head"
  ]
}